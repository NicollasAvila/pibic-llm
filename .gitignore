# --- SISTEMA & PYTHON (Padrão) ---
__pycache__/
*.py[cod]
.DS_Store
Thumbs.db

# --- SEGURANÇA (Crítico) ---
.env
.env.local

# --- AMBIENTE VIRTUAL ---
.venv/
venv/
env/

# --- IDE ---
.vscode/

# --- MODELOS (Pesados) ---
*.gguf
*.bin
# Ignora tudo na pasta modelos, exceto o arquivo .gitkeep
modelos/*
!modelos/.gitkeep

# --- DADOS & RAG (Onde moram os gigabytes) ---
# Ignora TODOS os arquivos de log globalmente para evitar acidentes
*.log

# Ignora tudo na pasta raw (e dados/raw), mantendo apenas o .gitkeep
dados/raw/*
!dados/raw/.gitkeep
raw/*
!raw/.gitkeep
!raw/dataset_sintetico.json

# Ignora os bancos de dados vetoriais gerados localmente
dados/vector_db/*
!dados/vector_db/.gitkeep
*.index

# --- RESULTADOS ---
# Ignora os relatórios gerados, mantém a pasta
resultados/*
!resultados/.gitkeep