# --- SISTEMA & PYTHON ---
__pycache__/
*.py[cod]
.DS_Store
Thumbs.db
.venv/
venv/
env/

# --- SEGURANÇA (Crítico) ---
.env
.env.local

# --- IDE ---
.vscode/
.idea/

# --- MODELOS LOCAIS (Pesados) ---
*.gguf
*.bin
modelos/*
!modelos/.gitkeep

# --- DADOS BRUTOS & LOGS (GigaBytes) ---
*.log
dados/raw/*
!dados/raw/.gitkeep

# --- BANCO DE DADOS VETORIAL (RAG) ---
dados/vector_db/*
!dados/vector_db/.gitkeep
*.index

# --- RESULTADOS & MEMÓRIA 24/7 (Dinâmicos) ---
# Impede que o Playbook, o Grafo e o dataset SFT sujem os commits
resultados/*
!resultados/.gitkeep